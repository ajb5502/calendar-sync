{
  "_comment": "Sample calendar-sync config. Copy to ~/.openclaw/calendar-sync.json and fill in your details.",
  "version": 1,
  "hub": {
    "provider": "google",
    "account": "your-personal@gmail.com",
    "calendarId": "primary"
  },
  "providers": {
    "google": {
      "accounts": ["your-personal@gmail.com"],
      "gogBinary": "gog"
    },
    "msgraph": {
      "accounts": [
        {
          "email": "you@company.com",
          "credentialsFile": "~/.openclaw/credentials/company-azure.json"
        }
      ],
      "tokenScript": "~/.openclaw/scripts/ms-graph-auth.py",
      "disableTelemetry": true
    }
  },
  "mappings": [
    {
      "name": "work-to-personal",
      "type": "full-detail",
      "source": {
        "provider": "msgraph",
        "account": "you@company.com",
        "calendarId": "primary"
      },
      "target": {
        "provider": "google",
        "account": "your-personal@gmail.com",
        "calendarId": "primary"
      },
      "lookaheadDays": 30,
      "skipDeclined": true,
      "allDayMode": "free",
      "color": { "google": "6" }
    },
    {
      "name": "personal-to-work",
      "type": "busy-block",
      "sources": [
        {
          "provider": "google",
          "account": "your-personal@gmail.com",
          "calendarId": "primary"
        },
        {
          "_comment": "Include sub-calendars (e.g. family filtered-copy target) so they show as busy on work",
          "provider": "google",
          "account": "your-personal@gmail.com",
          "calendarId": "your-subcal-id@group.calendar.google.com"
        }
      ],
      "target": {
        "provider": "msgraph",
        "account": "you@company.com",
        "calendarId": "primary"
      },
      "lookaheadDays": 30,
      "maxEventsPerMapping": 2000,
      "hold": {
        "visibility": "private",
        "showAs": "busy",
        "labelTasks": true
      },
      "_hold_options": "Remove 'summary' to use the source event title (you see the detail, shared viewers see 'Busy' due to private visibility). Set 'labelTasks: true' to sync Google Tasks time blocks as 'Task: <title>'."
    }
  ],
  "safety": {
    "maxChangesPerRun": 250,
    "maxEventsPerMapping": 2000,
    "dryRun": false,
    "_note": "maxEventsPerMapping must also be set on each mapping (engine reads from mapping, not global). This global value is for documentation only until the engine fallback is implemented."
  },
  "retry": {
    "maxRetries": 3,
    "backoffSeconds": [2, 4, 8]
  },
  "notifications": {
    "method": "stdout"
  },
  "state": {
    "file": "~/.openclaw/calendar-sync-state.json"
  }
}
